# Copy to .env and fill in real values before deploying.

# --- Core ---
SECRET_KEY=replace-with-a-long-random-string
ACCESS_TOKEN_EXPIRE_MINUTES=120
CORS_ORIGINS=https://your-frontend-domain.com,http://localhost:5173

# --- Database (leave unset to use local SQLite file ./ciap.db) ---
# DATABASE_URL=postgresql://ciap:ciap@localhost:5432/ciap

# --- Graph DB (once link-analysis endpoint is wired to Neo4j) ---
# NEO4J_URI=bolt://localhost:7687
# NEO4J_USER=neo4j
# NEO4J_PASSWORD=ciap_password

# --- Deployment port (most PaaS providers inject this automatically) ---
PORT=8000
